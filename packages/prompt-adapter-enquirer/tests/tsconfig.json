{
  "extends": "../tsconfig",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../",
    "sourceMap": true,
    "module": "ESNext",
    "target": "ESNext",
    "resolveJsonModule": true,
    "paths": {
      "@tests/utils": ["../tests/utils/index"],
      "@root": ["../src/index"]
    },
    "types": ["node", "jest"]
  },
  "include": ["../src", "../tests"],
  "exclude": ["node_modules", "dist"]
}
